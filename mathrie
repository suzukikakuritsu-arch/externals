-- n^t は t > 0 で単調増加
lemma rpow_lt_rpow_of_lt {t : ℝ} (ht : 0 < t)
    {m n : ℕ} (hmn : m < n) :
    (m+1:ℝ)^t < (n+1:ℝ)^t := by
  apply Real.rpow_lt_rpow
  · positivity
  · exact_mod_cast Nat.add_lt_add_right hmn 1
  · exact ht

-- 1/n^t は t > 0 で単調減少
lemma inv_rpow_antitone {t : ℝ} (ht : 0 < t) :
    Antitone (fun n : ℕ => 1 / (n+1:ℝ)^t) := by
  intro m n hmn
  apply div_le_div_of_nonneg_left one_pos
    (by positivity) (by positivity)
  apply Real.rpow_le_rpow <;>
  [positivity; exact_mod_cast Nat.add_le_add_right hmn 1; linarith]

-- 1/(n+1)^t → 0
lemma inv_rpow_tendsto_zero {t : ℝ} (ht : 0 < t) :
    Tendsto (fun n : ℕ => 1 / (n+1:ℝ)^t)
    atTop (nhds 0) := by
  simp only [one_div]
  apply Tendsto.inv_tendsto_atTop
  apply Tendsto.rpow_atTop ht
  apply Tendsto.atTop_add (tendsto_const_nhds) tendsto_natCast_atTop_atTop

-- 2^(1-t) > 1 for t ∈ (0,1)
lemma two_pow_gt_one {t : ℝ} (ht : 0 < t) (ht1 : t < 1) :
    1 < (2:ℝ)^(1-t) := by
  rw [show (1:ℝ) = (2:ℝ)^(0:ℝ) by simp]
  apply Real.rpow_lt_rpow_of_exponent_lt (by norm_num)
  linarith

-- 1 - 2^(1-t) < 0
lemma one_sub_two_pow_neg {t : ℝ} (ht : 0 < t) (ht1 : t < 1) :
    1 - (2:ℝ)^(1-t) < 0 := by
  linarith [two_pow_gt_one ht ht1]

-- 1 - 2^(1-t) ≠ 0
lemma one_sub_two_pow_ne {t : ℝ} (ht : 0 < t) (ht1 : t < 1) :
    1 - (2:ℝ)^(1-t) ≠ 0 :=
  ne_of_lt (one_sub_two_pow_neg ht ht1)

