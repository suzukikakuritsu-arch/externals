-- ζ(t) ≠ 0 for t ∈ (0,1) ∩ ℝ
-- axiom1 を使えば証明できる

theorem zeta_real_ne_zero {t : ℝ}
    (ht : 0 < t) (ht1 : t < 1) :
    riemannZeta (t:ℂ) ≠ 0 := by
  intro h
  -- ζ(t) = 0 → η(t) = 0
  have h_re : (riemannZeta (t:ℂ)).re = 0 := by
    simp [h]
  have h_eta : η t = 0 := by
    rw [η_zeta_relation t ht ht1, h_re, mul_zero]
  -- でも η(t) > 0
  linarith [η_pos ht ht1]

-- ================================================================
-- ☕ 主定理: axiom 2つを使って証明
-- ================================================================

theorem suzuki_riemann :
    ∀ s : ℂ,
    riemannZeta s = 0 →
    0 < s.re → s.re < 1 →
    s.re = 1/2 := by
  intro s hs h0 h1
  by_contra hne
  rcases lt_or_gt_of_ne hne with hlt | hgt

  -- Case 1: Re(s) < 1/2
  · by_cases him : s.im = 0
    · -- 実数: axiom1 で矛盾
      have hs_eq : s = (s.re : ℂ) :=
        Complex.ext rfl (by simp [him])
      rw [hs_eq] at hs
      exact zeta_real_ne_zero h0 hlt hs
    · -- 複素: axiom2 で矛盾
      exact no_complex_zero_off_line s hs h0 h1 hne him

  -- Case 2: Re(s) > 1/2
  · -- T(s) に Case 1 を適用
    have hT := zeta_T_zero hs
    have hT_strip := strip_T h0 h1
    have hT_lt : (1-s).re < 1/2 := by
      simp [Complex.sub_re]; linarith
    have hT_ne : (1-s).re ≠ 1/2 := ne_of_lt hT_lt
    by_cases hTim : (1-s).im = 0
    · -- T(s) が実数
      have hTs_eq : (1-s) = ((1-s).re : ℂ) :=
        Complex.ext rfl (by simp [hTim])
      rw [hTs_eq] at hT
      exact zeta_real_ne_zero hT_strip.1 hT_lt hT
    · -- T(s) が複素数: axiom2 で矛盾
      exact no_complex_zero_off_line
        (1-s) hT hT_strip.1 hT_strip.2 hT_ne hTim

