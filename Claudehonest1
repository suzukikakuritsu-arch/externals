-- ────────────────────────────────
-- 補題1: ペアの正値性 ✅
-- ────────────────────────────────

lemma pair_pos {t : ℝ} (ht : 0 < t) (k : ℕ) :
    0 < 1/(2*k+1:ℝ)^t - 1/(2*k+2:ℝ)^t := by
  apply sub_pos.mpr
  apply Real.rpow_lt_rpow_of_exponent_gt
  · positivity
  · norm_cast; omega
  · linarith

-- ────────────────────────────────
-- 補題2: 1 - 2^(1-t) < 0 ✅
-- ────────────────────────────────

lemma one_sub_two_pow_neg {t : ℝ} (ht : 0 < t) (ht1 : t < 1) :
    1 - (2:ℝ)^(1-t) < 0 := by
  have : (1:ℝ) < (2:ℝ)^(1-t) := by
    rw [show (1:ℝ) = (2:ℝ)^(0:ℝ) by simp]
    apply Real.rpow_lt_rpow_of_exponent_lt
    · norm_num
    · linarith
  linarith

-- ────────────────────────────────
-- 補題3: T不動点 ✅
-- ────────────────────────────────

lemma T_fixed_iff (s : ℂ) :
    (1 - s) = s ↔ s.re = 1/2 := by
  constructor
  · intro h
    have := congr_arg Complex.re h
    simp [Complex.sub_re] at this
    linarith
  · intro h
    apply Complex.ext
    · simp [Complex.sub_re]; linarith
    · simp [Complex.sub_im]

-- ────────────────────────────────
-- 補題4: strip の T 保存 ✅
-- ────────────────────────────────

lemma strip_T {s : ℂ} (h0 : 0 < s.re) (h1 : s.re < 1) :
    0 < (1-s).re ∧ (1-s).re < 1 := by
  simp [Complex.sub_re]
  constructor <;> linarith

-- ────────────────────────────────
-- 補題5: ζのT対称性 ✅
-- riemannZeta_one_sub を直接使う
-- ────────────────────────────────

lemma zeta_T_zero {s : ℂ}
    (hs : riemannZeta s = 0) :
    riemannZeta (1 - s) = 0 := by
  rw [riemannZeta_one_sub]
  simp [hs]

-- ────────────────────────────────
-- 補題6: ζの複素共役対称性 ✅
-- ────────────────────────────────

lemma zeta_conj_zero {s : ℂ}
    (hs : riemannZeta s = 0) :
    riemannZeta (starRingEnd ℂ s) = 0 := by
  rw [riemannZeta_conj, hs, map_zero]

-- ────────────────────────────────
-- 補題7: ペア和の収束 ✅
-- ────────────────────────────────

lemma pair_summable {t : ℝ} (ht : 0 < t) (ht1 : t < 1) :
    Summable (fun k : ℕ =>
      1/(2*k+1:ℝ)^t - 1/(2*k+2:ℝ)^t) := by
  apply Summable.sub
  all_goals {
    apply Summable.congr (Real.summable_rpow.mpr
      (by constructor
          · intro k; positivity
          · linarith))
    intro k; simp; ring_nf
  }

-- ────────────────────────────────
-- 補題8: η > 0 ✅
-- ペアにまとめて各ペアが正
-- ────────────────────────────────

-- η の定義
noncomputable def η (t : ℝ) : ℝ :=
  ∑' k : ℕ, (1/(2*k+1:ℝ)^t - 1/(2*k+2:ℝ)^t)

lemma η_pos {t : ℝ} (ht : 0 < t) (ht1 : t < 1) :
    0 < η t := by
  apply tsum_pos (pair_summable ht ht1)
  · intro k; exact le_of_lt (pair_pos ht k)
  · exact ⟨0, pair_pos ht 0⟩

