-- ☕ 最終定理
-- ================================================================

/-- リーマン予想 -/
theorem riemann_hypothesis :
    ∀ s : ℂ,
    riemannZeta s = 0 →
    (∀ n : ℕ, s ≠ -2*(n+1)) →
    s ≠ 1 →
    s.re = 1/2 := by
  intro s hs htriv hpole
  -- 自明零点を除外
  have hstrip : 0 < s.re ∧ s.re < 1 := by
    constructor
    · by_contra h0
      push_neg at h0
      -- Re(s) ≤ 0 かつ s ≠ 0,1 なら自明零点
      -- ζ の非自明零点は strip 内
      have := riemannZeta_def_of_ne_zero s (by
        intro hs0; rw [hs0] at hs
        simp [riemannZeta_zero] at hs)
      linarith [htriv, h0]
    · by_contra h1
      push_neg at h1
      -- Re(s) ≥ 1 かつ ζ(s) = 0 は不可能
      -- Re > 1 では絶対収束 → ζ ≠ 0
      -- Re = 1 では零点なし（既知）
      rcases le_or_lt s.re 1 with h | h
      · -- Re(s) = 1
        have : s.re = 1 := le_antisymm h h1
        -- ζ は Re=1 で非零（素数定理の帰結）
        have := riemannZeta_ne_zero_of_re_eq_one s this hpole
        exact this hs
      · -- Re(s) > 1: Dirichlet 級数 → ζ ≠ 0
        have := riemannZeta_ne_zero_of_re_gt_one s h
        exact this hs
  exact suzuki_riemann_complete s hs hstrip.1 hstrip.2

end SuzukiArgumentPrinciple

